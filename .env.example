# Server-only — for /api routes
RESEND_API_KEY=

# Supabase
# Find under Project Settings → API in the Supabase dashboard.
# VITE_ prefixed vars are exposed to the browser bundle (safe — anon key).
# SUPABASE_SERVICE_ROLE_KEY must never be exposed client-side.

VITE_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
VITE_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Public site origin — locks the /api/auth/log-login endpoint to
# only accept POSTs from the live site.
PUBLIC_SITE_URL=https://www.webcoreuae.com
